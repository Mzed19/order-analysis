# Em desenvolvimento (Vite + ngrok): use /api — o Vite faz proxy para o backend.
# Em produção com backend em outro host: URL absoluta, ex. https://xxx.ngrok-free.dev
VITE_BACKEND_URL=/api

# Alvo do proxy do Vite (dentro do Docker Compose use http://app:8003)
VITE_PROXY_TARGET=http://localhost:8003
